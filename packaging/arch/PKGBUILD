# Maintainer: Alvaro Gomero <alvarogomezruiz94@gmail.com>
pkgname=xlcli
pkgver=1.0.0
pkgrel=1
pkgdesc="Terminal spreadsheet editor with vim bindings and full Excel compat"
arch=('x86_64')
url="https://github.com/AGomeroR/XLCLI"
license=('GPL3')
makedepends=('cargo' 'make')
depends=('gcc-libs')
optdepends=(
  'xdg-utils: file association and Open-With integration'
  'desktop-file-utils: refresh launcher database'
  'gtk-update-icon-cache: refresh icon cache'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/AGomeroR/XLCLI/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')
install=xlcli.install

prepare() {
  cd "XLCLI-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo fetch --locked
}

build() {
  cd "XLCLI-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  CFLAGS+=' -ffat-lto-objects'
  make build
}

package() {
  cd "XLCLI-$pkgver"
  make install DESTDIR="$pkgdir" PREFIX=/usr
}
